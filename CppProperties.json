{
  "projectName": "Monorepo",
  "configurations": [
    {
      "name": "x64-FastBuild",
      "compilerSwitches": "/std:c++latest",
      "intelliSenseMode": "windows-msvc-x64",
      "inheritEnvironments": [
        "msvc_x64_x64"
      ],
      "environments": [
        {
          "BUILD_CONFIG": "fastbuild"
        }
      ],
      "includePath": [
        "${workspaceRoot}\\Code\\Projects\\**",
        "${workspaceRoot}\\bazel\\Code\\Projects\\**",
        "${workspaceRoot}\\bazel\\monorepo\\external\\**"
      ]
    },
    {
      "name": "x64-Debug",
      "compilerSwitches": "/std:c++latest",
      "intelliSenseMode": "windows-msvc-x64",
      "inheritEnvironments": [
        "msvc_x64_x64"
      ],
      "environments": [
        {
          "BUILD_CONFIG": "dbg"
        }
      ],
      "includePath": [
        "${workspaceRoot}\\Code\\Projects\\**",
        "${workspaceRoot}\\bazel\\Code\\Projects\\**",
        "${workspaceRoot}\\bazel\\monorepo\\external\\**"
      ]
    }
  ]
}